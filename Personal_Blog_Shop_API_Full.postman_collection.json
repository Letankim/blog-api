                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. REVIEWS + REPLIES - 20 CASES",
      "item": [
        {
          "name": "4.1 Get Reviews with Replies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/product-reviews?product_id={{product_id}}&page=1&limit=5"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has replies', () => { const json = pm.response.json(); if (json.data.length > 0) { pm.expect(json.data[0].replies).to.be.an('array'); } });",
                  "pm.test('Save review_id', () => { const json = pm.response.json(); if (json.data.length > 0) { pm.environment.set('review_id', json.data[0].id); } });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4.2 Get Replies by Review ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/review-replies?review_id={{review_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user_name', () => { const json = pm.response.json(); json.data.forEach(r => pm.expect(r.user_name).to.exist); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
