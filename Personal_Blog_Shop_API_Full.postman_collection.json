          ]
        },
        {
          "name": "3.2 Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/products/prod001"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
